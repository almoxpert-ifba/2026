# ──────────────────────────────────────────────────────────────
# Dependências
# ──────────────────────────────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ──────────────────────────────────────────────────────────────
# Build / Compilação
# ──────────────────────────────────────────────────────────────
dist/
*/dist/
**/dist/
build/
*/build/
**/build/
*.tsbuildinfo
*.js.map
*.d.ts.map
.nest/

# ──────────────────────────────────────────────────────────────
# Variáveis de Ambiente  ← DADOS SENSÍVEIS
# Nunca commitar .env com senhas reais ou chaves JWT
# Use os arquivos .env.example como referência
# ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.prod
.env.dev
.env.test
.env.production
apps/api/.env
apps/web/.env

# ──────────────────────────────────────────────────────────────
# Docker Compose de desenvolvimento  ← DADOS SENSÍVEIS
# Pode conter credenciais hardcoded de banco de dados local.
# Copie docker-compose.dev.yml.example e renomeie para usar.
# O docker-compose.yml de produção usa variáveis do .env.
# ──────────────────────────────────────────────────────────────
docker-compose.dev.yml
docker-compose.override.yml
docker-compose.yml

# ──────────────────────────────────────────────────────────────
# Lock files (use localmente, não versione)
# Cada desenvolvedor terá versões diferentes conforme suas dependências
# ──────────────────────────────────────────────────────────────
package-lock.json
*/package-lock.json
**/package-lock.json
yarn.lock
*/yarn.lock
**/yarn.lock
pnpm-lock.yaml
*/pnpm-lock.yaml
**/pnpm-lock.yaml

# ──────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ──────────────────────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/
*.tmp

# ──────────────────────────────────────────────────────────────
# Testes
# ──────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/

# ──────────────────────────────────────────────────────────────
# Banco de dados local (arquivos gerados, não o schema SQL)
# Os arquivos .sql em /database/ SÃO versionados (schema e migrations)
# ──────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
db.json

# ──────────────────────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.history/

# ──────────────────────────────────────────────────────────────
# Sistema Operacional
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ──────────────────────────────────────────────────────────────
# Cache
# ──────────────────────────────────────────────────────────────
.npm
.cache/
.parcel-cache/
.vite/
